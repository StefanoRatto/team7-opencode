# ============================================================================
# ARGUMENT PARSING
# ============================================================================

parse_args() {
  local positional=""

  while [[ $# -gt 0 ]]; do
    case $1 in
      --model)
        [[ -z "${2:-}" ]] && die_usage "--model requires an argument"
        MODEL_OVERRIDE="$2"
        shift 2
        ;;
      --dry-run)
        DRY_RUN=true
        shift
        ;;
      --max-iterations)
        is_uint "${2:-}" || die_usage "--max-iterations requires a non-negative integer"
        MAX_ITERATIONS="$2"
        shift 2
        ;;
      --max-retries)
        is_uint "${2:-}" || die_usage "--max-retries requires a non-negative integer"
        MAX_RETRIES="$2"
        shift 2
        ;;
      --retry-delay)
        is_uint "${2:-}" || die_usage "--retry-delay requires a non-negative integer"
        RETRY_DELAY="$2"
        shift 2
        ;;
      --ai-timeout)
        is_uint "${2:-}" || die_usage "--ai-timeout requires a non-negative integer"
        AI_TIMEOUT="$2"
        shift 2
        ;;
      --review-timeout)
        is_uint "${2:-}" || die_usage "--review-timeout requires a non-negative integer"
        REVIEW_TIMEOUT="$2"
        shift 2
        ;;
      --no-verify)
        VERIFY_ENABLED=false
        shift
        ;;
      --no-review)
        REVIEW_ENABLED=false
        shift
        ;;
      -v|--verbose)
        VERBOSE=true
        shift
        ;;
      -h|--help)
        show_help
        exit 0
        ;;
      --wprd-template)
        show_wprd_template
        exit 0
        ;;
      -*)
        die_usage "Unknown option: $1"
        ;;
      *)
        if [[ -z "$positional" ]]; then
          positional="$1"
        else
          positional="$positional $1"
        fi
        shift
        ;;
    esac
  done

  # Resolve mode from positional argument.
  # A positional argument is required: either a WPRD file path or a task string.
  if [[ -z "$positional" ]]; then
    show_help
    exit 0
  elif [[ -f "$positional" ]]; then
    WPRD_FILE="$positional"
    MODE="wprd"
  else
    SINGLE_TASK="$positional"
    MODE="single"
  fi

  # Dry run defaults to 1 iteration in WPRD mode.
  if [[ "$DRY_RUN" == true ]] && [[ "$MODE" == "wprd" ]] && [[ "$MAX_ITERATIONS" -eq 0 ]]; then
    MAX_ITERATIONS=1
  fi
}

# ============================================================================
# PRE-FLIGHT CHECKS
# ============================================================================

check_requirements() {
  if ! command -v opencode &>/dev/null; then
    log_error "team7 engine (opencode) not found."
    exit 1
  fi

  if ! command -v jq &>/dev/null; then
    log_error "jq not found."
    exit 1
  fi

  if [[ "$MODE" == "wprd" ]] && [[ ! -f "$WPRD_FILE" ]]; then
    log_error "$WPRD_FILE not found"
    log_info "Create a WPRD.md or pass a task: l7 \"your task\""
    exit 1
  fi
}

# ============================================================================
# CLEANUP HANDLER
#
# Called on EXIT (normal or signal-triggered). Kills any child processes we
# started and removes the temp file. The `set +e` at the top prevents
# cleanup itself from aborting on a failed kill.
# ============================================================================

cleanup() {
  local exit_code=$?
  set +e  # Don't let cleanup abort on errors

  [[ -n "$watchdog_pid" ]]    && kill "$watchdog_pid" 2>/dev/null
  [[ -n "$log_stream_pid" ]]  && kill "$log_stream_pid" 2>/dev/null
  [[ -n "$monitor_pid" ]]     && kill "$monitor_pid"  2>/dev/null
  [[ -n "$ai_pid" ]]          && kill "$ai_pid"       2>/dev/null
  wait 2>/dev/null  # Reap all children

  [[ -n "$tmpfile" ]] && rm -f "$tmpfile"

  # Finalize log on interruption
  if [[ -n "$run_log" ]] && [[ $exit_code -eq 130 ]]; then
    log_to_file "RUN INTERRUPTED" "Exit code: 130 (SIGINT)"
    write_stats_file 2>/dev/null || true
  fi

  if [[ $exit_code -eq 130 ]]; then
    printf "\n"
    log_warn "Interrupted."
    if [[ -n "$run_log" ]]; then
      printf "  ${L7_BLUE}Log:${RESET}   ${DIM}%s${RESET}\n" "$run_log"
      printf "  ${L7_BLUE}Stats:${RESET} ${DIM}%s${RESET}\n" "$run_stats"
    fi
  fi
}

# ============================================================================
# WPRD TITLE EXTRACTION
# ============================================================================

# Extract the title from the WPRD file. Looks for the first line after
# "## Title" that contains non-whitespace text. Returns empty if no
# title section or no text found.
get_wprd_title() {
  local in_title=false
  while IFS= read -r line; do
    if [[ "$line" =~ ^##[[:space:]]+Title[[:space:]]*$ ]]; then
      in_title=true
      continue
    fi
    if [[ "$in_title" == true ]]; then
      # Skip blank lines
      if [[ -z "${line// /}" ]]; then
        continue
      fi
      # Stop at next section
      if [[ "$line" =~ ^## ]]; then
        break
      fi
      # Return first non-blank line as the title
      printf '%s' "$line"
      return
    fi
  done < "$WPRD_FILE"
}

# Extract the full text content of a named ## section from the WPRD file.
# Captures everything between the matching "## <name>" header and the next
# "## " header (or end of file). Strips leading/trailing blank lines.
# Usage: get_wprd_section "Context"
get_wprd_section() {
  local target_section=$1
  local in_section=false
  local content=""
  while IFS= read -r line; do
    if [[ "$line" =~ ^##[[:space:]]+"$target_section"[[:space:]]*$ ]]; then
      in_section=true
      continue
    fi
    if [[ "$in_section" == true ]]; then
      # Stop at next section header
      if [[ "$line" =~ ^## ]]; then
        break
      fi
      content+="${line}"$'\n'
    fi
  done < "$WPRD_FILE"

  # Strip leading and trailing blank lines
  content=$(printf '%s' "$content" | sed '/./,$!d' | sed -e :a -e '/^[[:space:]]*$/{ $d; N; ba; }')
  printf '%s' "$content"
}

# ============================================================================
# TASK MANAGEMENT (Markdown checkboxes)
#
# Tasks in the WPRD file use checkbox notation with 4 states:
#   - [ ] pending     (to do -- will be picked up)
#   - [\] in progress (currently being worked on)
#   - [+] completed   (finished successfully)
#   - [x] failed      (did not complete after retries, or unlimited retries stopped by breaker)
#
# Tasks can optionally have verify: and accept: lines immediately after them:
#   - [ ] Create the config file
#     verify: test -f config.yaml
#     verify: grep -q "database" config.yaml
#     accept: Config contains database host, port, and credentials
#     accept: Uses YAML format with proper indentation
#
# verify: = shell commands (deterministic, must exit 0)
# accept: = natural-language criteria (checked by AI reviewer)
#
# The AI engine is expected to mark tasks done by editing the WPRD file
# (changing '- [ ]' to '- [+]'). l7 also manages state transitions:
#   [ ] -> [\]  when a task is picked up (mark_task_in_progress)
#   [\] -> [+]  when a task passes verification (mark_task_done)
#   [\] -> [x]  when a task fails all retries (mark_task_failed)
#   [ ] -> [+]  safety net if AI marked it directly
# ============================================================================

# Return the text of the first pending task, or empty string if none.
# Looks for both [ ] (pending) and [\] (in progress, e.g. from a prior
# interrupted run).
get_next_task() {
  local line
  # First check for in-progress tasks (resume interrupted work)
  line=$(grep -m1 '^\- \[\\]' "$WPRD_FILE" 2>/dev/null || true)
  if [[ -z "$line" ]]; then
    # Then check for pending tasks
    line=$(grep -m1 '^\- \[ \]' "$WPRD_FILE" 2>/dev/null || true)
  fi
  if [[ -n "$line" ]]; then
    printf '%s' "$line" | sed 's/^- \[.\] //'
  fi
}

# Extract verify: commands for a task at the given line number.
# Reads consecutive indented lines immediately following the task.
# Returns only verify: commands (one per line, without the "verify:" prefix).
# Skips accept: lines and result bullet lines (e.g. "  - some result").
get_verify_commands() {
  local task_line=$1
  local line_num=$((task_line + 1))
  local total_lines
  total_lines=$(wc -l < "$WPRD_FILE" 2>/dev/null || echo "0")

  while [[ $line_num -le $total_lines ]]; do
    local line
    line=$(sed -n "${line_num}p" "$WPRD_FILE" 2>/dev/null || true)

    # Match indented verify: lines
    if [[ "$line" =~ ^[[:space:]]+verify:[[:space:]]*(.*) ]]; then
      local cmd="${BASH_REMATCH[1]}"
      cmd="${cmd#"${cmd%%[![:space:]]*}"}"
      cmd="${cmd%"${cmd##*[![:space:]]}"}"
      if [[ -n "$cmd" ]]; then
        printf '%s\n' "$cmd"
      fi
      ((line_num++)) || true
    # Skip accept: lines (they belong to the same task block)
    elif [[ "$line" =~ ^[[:space:]]+accept:[[:space:]]* ]]; then
      ((line_num++)) || true
    # Skip other indented lines (result bullets, notes added by AI)
    elif [[ "$line" =~ ^[[:space:]]+ ]]; then
      ((line_num++)) || true
    else
      break  # Non-indented line = next task or section boundary
    fi
  done
}

# Extract accept: criteria for a task at the given line number.
# Reads consecutive indented lines immediately following the task.
# Returns only accept: criteria (one per line, without the "accept:" prefix).
# Skips verify: lines and result bullet lines (e.g. "  - some result").
get_accept_criteria() {
  local task_line=$1
  local line_num=$((task_line + 1))
  local total_lines
  total_lines=$(wc -l < "$WPRD_FILE" 2>/dev/null || echo "0")

  while [[ $line_num -le $total_lines ]]; do
    local line
    line=$(sed -n "${line_num}p" "$WPRD_FILE" 2>/dev/null || true)

    # Match indented accept: lines
    if [[ "$line" =~ ^[[:space:]]+accept:[[:space:]]*(.*) ]]; then
      local criteria="${BASH_REMATCH[1]}"
      criteria="${criteria#"${criteria%%[![:space:]]*}"}"
      criteria="${criteria%"${criteria##*[![:space:]]}"}"
      if [[ -n "$criteria" ]]; then
        printf '%s\n' "$criteria"
      fi
      ((line_num++)) || true
    # Skip verify: lines (they belong to the same task block)
    elif [[ "$line" =~ ^[[:space:]]+verify:[[:space:]]* ]]; then
      ((line_num++)) || true
    # Skip other indented lines (result bullets, notes added by AI)
    elif [[ "$line" =~ ^[[:space:]]+ ]]; then
      ((line_num++)) || true
    else
      break  # Non-indented line = next task or section boundary
    fi
  done
}

# Count pending tasks ([ ] only, not [\] in-progress).
count_remaining() {
  local n
  n=$(grep -c '^\- \[ \]' "$WPRD_FILE" 2>/dev/null) || true
  printf '%s' "${n:-0}"
}

# Count in-progress tasks ([\]).
count_in_progress() {
  local n
  n=$(grep -c '^\- \[\\]' "$WPRD_FILE" 2>/dev/null) || true
  printf '%s' "${n:-0}"
}

# Count completed tasks ([+]).
count_completed() {
  local n
  n=$(grep -c '^\- \[+\]' "$WPRD_FILE" 2>/dev/null) || true
  printf '%s' "${n:-0}"
}

# Count failed tasks ([x]).
count_failed() {
  local n
  n=$(grep -c '^\- \[x\]' "$WPRD_FILE" 2>/dev/null) || true
  printf '%s' "${n:-0}"
}

# Mark a task as in-progress: [ ] -> [\]
mark_task_in_progress() {
  local task="$1"
  local escaped_task
  escaped_task=$(printf '%s\n' "$task" | sed 's/[[\.*^$/&|]/\\&/g')
  sed -i.bak "s|^- \[ \] ${escaped_task}|- [\\\\] ${escaped_task}|" "$WPRD_FILE"
  rm -f "${WPRD_FILE}.bak"
}

# Mark a task as completed: [\] -> [+] (or [ ] -> [+] as safety net)
mark_task_done() {
  local task="$1"
  local escaped_task
  escaped_task=$(printf '%s\n' "$task" | sed 's/[[\.*^$/&|]/\\&/g')
  # Try in-progress first, then pending as fallback
  if grep -q "^- \[\\\\] ${escaped_task}" "$WPRD_FILE" 2>/dev/null; then
    sed -i.bak "s|^- \[\\\\] ${escaped_task}|- [+] ${escaped_task}|" "$WPRD_FILE"
  else
    sed -i.bak "s|^- \[ \] ${escaped_task}|- [+] ${escaped_task}|" "$WPRD_FILE"
  fi
  rm -f "${WPRD_FILE}.bak"
}

# Mark a task as failed: [\] -> [x] (or [ ] -> [x] as fallback)
mark_task_failed() {
  local task="$1"
  local escaped_task
  escaped_task=$(printf '%s\n' "$task" | sed 's/[[\.*^$/&|]/\\&/g')
  if grep -q "^- \[\\\\] ${escaped_task}" "$WPRD_FILE" 2>/dev/null; then
    sed -i.bak "s|^- \[\\\\] ${escaped_task}|- [x] ${escaped_task}|" "$WPRD_FILE"
  else
    sed -i.bak "s|^- \[ \] ${escaped_task}|- [x] ${escaped_task}|" "$WPRD_FILE"
  fi
  rm -f "${WPRD_FILE}.bak"
}

# Find the line number of a task by its exact text, regardless of marker state.
# Matches any marker ([+], [x], [\], [ ]) followed by the exact task text.
# Returns the line number (1-indexed) or empty string if not found.
find_task_line() {
  local task="$1"
  while IFS= read -r match; do
    local line_num="${match%%:*}"
    local line_text="${match#*:}"
    # Remove the "- [X] " prefix using glob pattern (? matches any marker char)
    local extracted_task="${line_text#- \[?\] }"
    if [[ "$extracted_task" == "$task" ]]; then
      printf '%s' "$line_num"
      return
    fi
  done < <(grep -n "^- \[.\] " "$WPRD_FILE" 2>/dev/null || true)
}

# Ensure a task is marked [\] (in progress). If the AI marked it [+] during
# a failed attempt, this resets it so the retry sees the correct state.
# Handles any marker state -> [\].
ensure_task_in_progress() {
  local task="$1"
  local escaped_task
  escaped_task=$(printf '%s\n' "$task" | sed 's/[[\.*^$/&|]/\\&/g')
  # Only act if the task is NOT already [\]
  if ! grep -q "^- \[\\\\] ${escaped_task}" "$WPRD_FILE" 2>/dev/null; then
    sed -i.bak "s|^- \[.\] ${escaped_task}|- [\\\\] ${escaped_task}|" "$WPRD_FILE"
    rm -f "${WPRD_FILE}.bak"
  fi
}

# ============================================================================
# VERIFY CHECKS
#
# Runs shell commands defined in the WPRD after a task's checkbox line.
# Each "verify:" line is a shell command that must exit 0 for the task
# to be considered complete. If any verify command fails, the task fails.
#
# Format in WPRD:
#   - [ ] Build the Docker image
#     verify: docker image inspect myapp:latest >/dev/null 2>&1
#     verify: test -f Dockerfile
#
# Verify commands run in the current working directory with the user's
# shell environment. They are plain shell commands -- not AI prompts.
# ============================================================================

# Run all verify: commands for a task. Returns 0 if all pass (or none exist).
# Returns 1 if any command fails. Prints pass/fail status for each command.
run_verify_checks() {
  local task_line=$1
  local task_text=$2

  if [[ "$VERIFY_ENABLED" != true ]]; then
    log_debug "Verify checks disabled (--no-verify)"
    return 0
  fi

  # Collect verify commands
  local commands=()
  while IFS= read -r cmd; do
    [[ -n "$cmd" ]] && commands+=("$cmd")
  done < <(get_verify_commands "$task_line")

  if [[ ${#commands[@]} -eq 0 ]]; then
    log_debug "No verify: commands for this task"
    return 0
  fi

  printf "  ${L7_BLUE}verify${RESET}  ${DIM}%d check(s)${RESET}\n" "${#commands[@]}"

  local all_passed=true
  local idx=0
  for cmd in "${commands[@]}"; do
    ((idx++)) || true
    local display_cmd="$cmd"
    # Truncate long commands for display
    if [[ ${#display_cmd} -gt 60 ]]; then
      display_cmd="${display_cmd:0:57}..."
    fi

    local exit_code=0
    local output
    output=$(eval "$cmd" 2>&1) || exit_code=$?

    if [[ $exit_code -eq 0 ]]; then
      log_pass "${L7_BLUE}(${idx}/${#commands[@]})${RESET} ${L7_BLUE}${display_cmd}${RESET}"
      ((total_verify_passed++)) || true
      log_to_file "VERIFY PASS" "Command: ${cmd}"
    else
      log_fail "${L7_BLUE}(${idx}/${#commands[@]})${RESET} ${L7_ERR}${display_cmd}${RESET}"
      if [[ -n "$output" ]]; then
        # Show first 3 lines of output on failure
        printf '%s\n' "$output" | head -3 | while IFS= read -r line; do
          printf "         ${DIM}%s${RESET}\n" "$line"
        done
      fi
      all_passed=false
      ((total_verify_failed++)) || true
      log_to_file "VERIFY FAIL" "Command: ${cmd}\nOutput: ${output}"
    fi
  done

  if [[ "$all_passed" == true ]]; then
    return 0
  else
    return 1
  fi
}

# ============================================================================
# AI REVIEW PASS
#
# After the worker AI completes a task (and verify checks pass), a second
# AI call reviews the work. The reviewer gets the task description, the
# WPRD context, and is asked to check whether the task was actually done.
#
# The reviewer returns a structured verdict:
#   <verdict>PASS</verdict>   -- task is done
#   <verdict>FAIL</verdict>   -- task is not done, with explanation
#
# If the reviewer says FAIL, the task is retried. This catches cases where
# the AI claimed completion but didn't actually do the work, or did it
# incorrectly.
#
# The review uses a shorter timeout since it's a read-only inspection.
# ============================================================================

# Run the AI review pass for a completed task.
# Accepts optional accept: criteria that the reviewer should check against.
# Returns 0 if the reviewer says PASS (or review is disabled).
# Returns 1 if the reviewer says FAIL.
# Prints the verdict and any explanation.
run_ai_review() {
  local task_text=$1
  local task_line="${2:-}"

  if [[ "$REVIEW_ENABLED" != true ]]; then
    log_debug "AI review disabled (--no-review)"
    return 0
  fi

  printf "  ${L7_BLUE}review${RESET}  ${DIM}verifying...${RESET}\n"

  local review_prompt
  review_prompt=$(build_review_prompt "$task_text" "$task_line")

  ((total_agent_calls++)) || true
  log_to_file "REVIEW CALL #${total_agent_calls} - PROMPT SENT" "$review_prompt"

  local review_tmpfile
  review_tmpfile=$(mktemp -t l7-review.XXXXXX)

  # Build command array
  local cmd_args=(opencode run --format json)
  [[ -n "$MODEL_OVERRIDE" ]] && cmd_args+=(--model "$MODEL_OVERRIDE")
  cmd_args+=("$review_prompt")

  # Run the review AI (foreground with timeout, no spinner needed -- it's fast)
  local review_pid
  OPENCODE_PERMISSION='{"*":"allow"}' "${cmd_args[@]}" \
    > "$review_tmpfile" 2>/dev/null &
  review_pid=$!

  # Watchdog for review
  local review_watchdog_pid
  ( sleep "$REVIEW_TIMEOUT" && kill "$review_pid" 2>/dev/null ) &
  review_watchdog_pid=$!

  # Simple spinner for review (inline, no background process)
  local spinstr='|/-\'
  local spin_idx=0
  while kill -0 "$review_pid" 2>/dev/null; do
    local sc="${spinstr:$spin_idx:1}"
    printf "\r  ${L7_BLUE}%s${RESET} ${DIM}reviewing...${RESET}  " "$sc"
    spin_idx=$(( (spin_idx + 1) % ${#spinstr} ))
    sleep 0.3 2>/dev/null || sleep 1
  done
  wait "$review_pid" 2>/dev/null || true

  # Cancel watchdog
  kill "$review_watchdog_pid" 2>/dev/null || true
  wait "$review_watchdog_pid" 2>/dev/null || true

  # Clear spinner line
  tput cr 2>/dev/null || printf "\r"
  tput el 2>/dev/null || true

  local review_result
  review_result=$(cat "$review_tmpfile" 2>/dev/null || true)

  if [[ -z "$review_result" ]]; then
    rm -f "$review_tmpfile"
    log_warn "Review returned empty response, treating as PASS"
    return 0
  fi

  # Parse token usage from review
  local review_response="" review_in=0 review_out=0 review_cost="0"
  parse_ai_result "$review_result" review_response review_in review_out review_cost
  accumulate_usage "$review_in" "$review_out" "$review_cost"

  # Log the review interaction (must happen before deleting the temp file)
  log_ai_raw "REVIEW RESPONSE" "$review_tmpfile"
  log_to_file "REVIEW RESPONSE PARSED" "Tokens: ${review_in} in / ${review_out} out | Cost: ${review_cost}"
  rm -f "$review_tmpfile"

  # Extract verdict from response
  local verdict="PASS"  # Default to PASS if no verdict tag found
  if [[ "$review_response" == *"<verdict>FAIL</verdict>"* ]]; then
    verdict="FAIL"
  elif [[ "$review_response" == *"<verdict>PASS</verdict>"* ]]; then
    verdict="PASS"
  else
    # Try case-insensitive match on the raw text
    local lower_response
    lower_response=$(printf '%s' "$review_response" | tr '[:upper:]' '[:lower:]')
    if [[ "$lower_response" == *"verdict: fail"* ]] || [[ "$lower_response" == *"<verdict>fail</verdict>"* ]]; then
      verdict="FAIL"
    fi
  fi

  if [[ "$verdict" == "PASS" ]]; then
    printf '%s\n' "  ${L7_GOLD}[PASS]${RESET}  ${L7_BLUE}review passed${RESET}"
    ((total_review_passed++)) || true
    log_to_file "REVIEW VERDICT: PASS" ""
    return 0
  else
    printf '%s\n' "  ${L7_ERR}[FAIL]${RESET}  ${L7_ERR}review failed${RESET}"
    # Extract explanation (text between verdict tags or after "Reason:")
    local explanation=""
    if [[ "$review_response" =~ \<explanation\>(.*)\</explanation\> ]]; then
      explanation="${BASH_REMATCH[1]}"
    elif [[ "$review_response" =~ Reason:[[:space:]]*(.*) ]]; then
      explanation="${BASH_REMATCH[1]}"
    fi
    if [[ -n "$explanation" ]]; then
      # Show first 3 lines of explanation
      printf '%s\n' "$explanation" | head -3 | while IFS= read -r line; do
        printf "          ${DIM}%s${RESET}\n" "$line"
      done
    fi
    ((total_review_failed++)) || true
    log_to_file "REVIEW VERDICT: FAIL" "${explanation}"
    return 1
  fi
}

# Build the prompt for the AI review pass.
# Extracts Rules of Engagement from the WPRD and includes them as an
# explicit checklist the reviewer must verify -- alongside accept: criteria.
# This means RoE are enforced on every task, not just suggested.
build_review_prompt() {
  local task_text=$1
  local task_line="${2:-}"

  # Extract Rules of Engagement for enforcement
  local roe_text=""
  roe_text=$(get_wprd_section "Rules of Engagement")

  local roe_section=""
  if [[ -n "$roe_text" ]]; then
    roe_section="
RULES OF ENGAGEMENT (the author defined these -- verify compliance):
${roe_text}

If the work violates ANY rule above, verdict is FAIL.
Include which rules were followed and which were violated in your explanation.
"
  fi

  # Collect accept: criteria if available
  local accept_section=""
  if [[ -n "$task_line" ]]; then
    local criteria
    criteria=$(get_accept_criteria "$task_line")
    if [[ -n "$criteria" ]]; then
      accept_section="
ACCEPTANCE CRITERIA (check each one):
"
      local idx=0
      while IFS= read -r criterion; do
        ((idx++)) || true
        accept_section+="  ${idx}. ${criterion}
"
      done <<< "$criteria"
      accept_section+="
If ANY criterion is not met, verdict is FAIL.
Include which criteria passed and which failed in your explanation.
"
    fi
  fi

  cat << EOF
@${WPRD_FILE}

You are a REVIEWER. Your job is to verify whether a task was completed correctly
AND whether the Rules of Engagement were followed.

THE TASK THAT WAS JUST ATTEMPTED:
${task_text}
${roe_section}${accept_section}
REVIEW CHECKLIST:
1. Was the task actually completed? Look for concrete evidence: files created, code written, output produced.
2. Were all Rules of Engagement followed? Check each rule against the actual work.
3. Were all acceptance criteria met (if any)?
4. Do NOT implement anything. Do NOT modify any files. You are READ-ONLY.
5. Be strict: if the task says "create X" and X doesn't exist, that's a FAIL.
6. Be strict: if a rule says "use X" and the work uses Y instead, that's a FAIL.
7. Be practical: minor formatting differences are fine, missing deliverables are not.

RESPOND WITH EXACTLY THIS FORMAT:
<verdict>PASS</verdict> or <verdict>FAIL</verdict>
<explanation>Brief explanation of what you found (1-3 sentences)</explanation>

Examples:
  <verdict>PASS</verdict>
  <explanation>The config.yaml file exists with correct settings. All rules followed: uses YAML format, no hardcoded secrets.</explanation>

  <verdict>FAIL</verdict>
  <explanation>Task completed but violates Rules of Engagement: code uses an ORM (SQLAlchemy) when rules specify raw SQL only.</explanation>
EOF
}

# ============================================================================
# PROGRESS DASHBOARD
# ============================================================================

# Draw a progress bar: [========>...........] 3/7 (42%)
#
# Args: $1=completed  $2=total  $3=bar_width (default 30)
draw_progress_bar() {
  local completed=$1
  local total=$2
  local width=${3:-30}

  if [[ $total -le 0 ]]; then
    printf "[%*s] 0/0" "$width" ""
    return
  fi

  local pct=$((completed * 100 / total))
  local filled=$((completed * width / total))
  [[ $filled -gt $width ]] && filled=$width
  local empty=$((width - filled))

  local bar=""
  local i
  for ((i = 0; i < filled; i++)); do bar+="="; done

  if [[ $empty -gt 0 ]]; then
    if [[ $filled -lt $width ]]; then
      bar+=">"
      empty=$((empty - 1))
    fi
    for ((i = 0; i < empty; i++)); do bar+="."; done
  fi

  printf "[%s] %d/%d (%d%%)" "$bar" "$completed" "$total" "$pct"
}

# Show the task list dashboard with a progress bar and per-task status.
# Recognizes 4 states: [ ] pending, [\] in-progress, [+] completed, [x] failed.
# For lists with >15 tasks, shows a window around the current task.
show_task_dashboard() {
  local remaining completed failed in_progress total
  remaining=$(count_remaining)
  completed=$(count_completed)
  failed=$(count_failed)
  in_progress=$(count_in_progress)
  remaining="${remaining//[[:space:]]/}"
  completed="${completed//[[:space:]]/}"
  failed="${failed//[[:space:]]/}"
  in_progress="${in_progress//[[:space:]]/}"
  remaining=${remaining:-0}
  completed=${completed:-0}
  failed=${failed:-0}
  in_progress=${in_progress:-0}
  total=$((completed + failed + in_progress + remaining))

  local term_width
  term_width=$(tput cols 2>/dev/null || echo 80)

  # Narrow terminal fallback
  if [[ $term_width -lt 40 ]]; then
    echo ""
    printf '%s\n' "  ${L7_GOLD}$completed${RESET}${L7_BLUE}/$total done${RESET}"
    return
  fi

  local bar_width=$((term_width - 28))
  [[ $bar_width -lt 10 ]] && bar_width=10
  [[ $bar_width -gt 50 ]] && bar_width=50

  echo ""
  printf "  "
  local bar_str
  bar_str=$(draw_progress_bar "$completed" "$total" "$bar_width")
  printf '%s\n' "${L7_BLUE}${bar_str}${RESET}"

  local max_task_width=$((term_width - 8))
  [[ $max_task_width -lt 20 ]] && max_task_width=20

  # Parse all task lines from the WPRD in a single pass.
  # Matches all 4 states: [ ] [\] [+] [x]
  local all_tasks=()
  local all_statuses=()
  while IFS= read -r line; do
    local status="" text=""
    if [[ "$line" == "- [+] "* ]]; then
      status="done"
      text="${line#- \[+\] }"
    elif [[ "$line" == "- [x] "* ]]; then
      status="failed"
      text="${line#- \[x\] }"
    elif [[ "$line" == *'[\] '* ]]; then
      status="active"
      # Strip "- [\] " prefix -- backslash needs careful handling
      text="${line#*\\] }"
    elif [[ "$line" == "- [ ] "* ]]; then
      status="pending"
      text="${line#- \[ \] }"
    else
      continue
    fi
    all_tasks+=("$text")
    all_statuses+=("$status")
  done < <(grep -E '^\- \[[ +x\\]\] ' "$WPRD_FILE" 2>/dev/null || true)

  local task_count=${#all_tasks[@]}

  # Windowing for large lists: show 3 before + current + 5 after.
  local show_start=0
  local show_end=$task_count
  local truncated_before=0
  local truncated_after=0

  if [[ $task_count -gt 15 ]]; then
    local current_idx=0 idx
    for ((idx = 0; idx < task_count; idx++)); do
      if [[ "${all_statuses[$idx]}" == "active" ]] || [[ "${all_statuses[$idx]}" == "pending" ]]; then
        current_idx=$idx
        break
      fi
    done

    show_start=$((current_idx - 3))
    [[ $show_start -lt 0 ]] && show_start=0
    show_end=$((current_idx + 6))
    [[ $show_end -gt $task_count ]] && show_end=$task_count

    truncated_before=$show_start
    truncated_after=$((task_count - show_end))
  fi

  if [[ $truncated_before -gt 0 ]]; then
    printf '%s\n' "  ${L7_BLUE}... $truncated_before earlier${RESET}"
  fi

  local first_pending_shown=false idx
  for ((idx = show_start; idx < show_end; idx++)); do
    local text="${all_tasks[$idx]}"
    local status="${all_statuses[$idx]}"

    if [[ ${#text} -gt $max_task_width ]]; then
      text="${text:0:$((max_task_width - 3))}..."
    fi

    case "$status" in
      done)
        printf '%s\n' "  ${L7_GOLD}[+]${RESET} ${L7_BLUE}${text}${RESET}"
        ;;
      failed)
        printf '%s\n' "  ${L7_ERR}[x]${RESET} ${L7_ERR}${text}${RESET}"
        ;;
      active)
        printf '%s\n' "  ${L7_BLUE}${BOLD}[\\]${RESET} ${L7_BLUE}${BOLD}${text}${RESET}"
        ;;
      pending)
        if [[ "$first_pending_shown" == false ]]; then
          printf '%s\n' "  ${L7_BLUE}${BOLD}[>]${RESET} ${L7_BLUE}${text}${RESET}"
          first_pending_shown=true
        else
          printf '%s\n' "  ${DIM}[ ] ${text}${RESET}"
        fi
        ;;
    esac
  done

  if [[ $truncated_after -gt 0 ]]; then
    printf '%s\n' "  ${L7_BLUE}... $truncated_after more${RESET}"
  fi

  # Live telemetry footer
  local tele_parts=()
  if [[ -n "$run_start_time" ]]; then
    local now elapsed_secs
    now=$(date +%s)
    elapsed_secs=$((now - run_start_time))
    tele_parts+=("$(format_elapsed "$elapsed_secs")")
  fi
  tele_parts+=("${total_agent_calls} calls")
  if command -v bc &>/dev/null; then
    local has_cost
    has_cost=$(echo "$total_actual_cost > 0" | bc 2>/dev/null || echo "0")
    if [[ "$has_cost" == "1" ]]; then
      local cost_fmt
      cost_fmt=$(format_cost "$total_actual_cost")
      tele_parts+=("${cost_fmt}")
    fi
  fi
  [[ "$VERIFY_ENABLED" != true ]] && tele_parts+=("no-verify")
  [[ "$REVIEW_ENABLED" != true ]] && tele_parts+=("no-review")

  local tele_str=""
  for part in "${tele_parts[@]}"; do
    [[ -n "$tele_str" ]] && tele_str+="  ${DIM}·${RESET}  "
    tele_str+="${L7_BLUE}${part}${RESET}"
  done
  printf '  %s\n' "$tele_str"
}

# ============================================================================
# PROGRESS MONITOR
#
# Runs as a background process. Reads the tail of the AI output file to
# detect the current activity phase (Thinking/Reading/Working/Executing)
# and displays a spinner with elapsed time.
#
# Uses bash pattern matching instead of forking grep for each check,
# reducing process overhead from ~32 forks/sec to near zero.
# ============================================================================

monitor_progress() {
  local file=$1
  local task="${2:0:40}"
  local current_step="Thinking"
  local start_time
  start_time=$(date +%s)
  local spinstr='|/-\'
  local spin_idx=0

  while true; do
    local elapsed=$(($(date +%s) - start_time))
    local mins=$((elapsed / 60))
    local secs=$((elapsed % 60))

    # Detect current step from AI JSON output using bash builtins
    # instead of forking grep on every cycle.
    if [[ -f "$file" ]] && [[ -s "$file" ]]; then
      local content
      content=$(tail -c 5000 "$file" 2>/dev/null || true)

      if [[ "$content" == *'"tool":"Write"'* ]] || [[ "$content" == *'"tool":"Edit"'* ]] \
         || [[ "$content" == *'"name":"write"'* ]] || [[ "$content" == *'"name":"edit"'* ]]; then
        current_step="Working"
      elif [[ "$content" == *'"tool":"Read"'* ]] || [[ "$content" == *'"tool":"Glob"'* ]] \
           || [[ "$content" == *'"tool":"Grep"'* ]] || [[ "$content" == *'"name":"read"'* ]] \
           || [[ "$content" == *'"name":"glob"'* ]] || [[ "$content" == *'"name":"grep"'* ]]; then
        current_step="Reading"
      elif [[ "$content" == *'"tool":"Bash"'* ]] || [[ "$content" == *'"name":"bash"'* ]]; then
        current_step="Executing"
      elif [[ "$content" == *'WPRD.md'* ]]; then
        current_step="Updating WPRD"
      fi
    fi

    local spinner_char="${spinstr:$spin_idx:1}"
    local step_color=""

    case "$current_step" in
      "Thinking"|"Reading") step_color="$L7_BLUE" ;;
      "Working")            step_color="$L7_GOLD" ;;
      "Executing")          step_color="$L7_BLUE" ;;
      "Updating WPRD")       step_color="$L7_BLUE" ;;
      *)                    step_color="$L7_BLUE" ;;
    esac

    tput cr 2>/dev/null || printf "\r"
    tput el 2>/dev/null || true
    printf "  ${L7_BLUE}%s${RESET} ${step_color}%-14s${RESET} ${L7_BLUE}%s${RESET} ${DIM}%02d:%02d${RESET}" \
      "$spinner_char" "$current_step" "$task" "$mins" "$secs"

    spin_idx=$(( (spin_idx + 1) % ${#spinstr} ))
    sleep 0.12 2>/dev/null || sleep 1
  done
}

# ============================================================================
# PROMPT BUILDER
# ============================================================================

# Build the prompt for WPRD mode. Extracts Context and Rules of Engagement
# from the WPRD and injects them as explicit prompt sections so the LLM
# treats them with structural authority rather than as buried document text.
# The full WPRD file is still included via @file for complete reference.
#
# Args: $1=task_line_number (for accept: extraction)  $2=task_text (explicit task)
build_wprd_prompt() {
  local task_line="${1:-}"
  local task_text="${2:-}"

  # Extract structured sections from the WPRD
  local context_text=""
  local roe_text=""
  context_text=$(get_wprd_section "Context")
  roe_text=$(get_wprd_section "Rules of Engagement")

  # Build context block (placed first to frame the agent's thinking)
  local context_block=""
  if [[ -n "$context_text" ]]; then
    context_block="CONTEXT (your working environment):
${context_text}

"
  fi

  # Build rules block (explicit constraints the reviewer will check)
  local rules_block=""
  if [[ -n "$roe_text" ]]; then
    rules_block="RULES OF ENGAGEMENT (you MUST follow these -- the reviewer will verify compliance):
${roe_text}

"
  fi

  # Collect accept: criteria for the current task if available
  local accept_block=""
  if [[ -n "$task_line" ]]; then
    local criteria
    criteria=$(get_accept_criteria "$task_line")
    if [[ -n "$criteria" ]]; then
      accept_block="
ACCEPTANCE CRITERIA (will be checked after you finish):
"
      while IFS= read -r criterion; do
        accept_block+="   - ${criterion}
"
      done <<< "$criteria"
      accept_block+="
"
    fi
  fi

  cat << EOF
@${WPRD_FILE}

${context_block}${rules_block}YOUR TASK:
Implement this specific task from the WPRD above:

  ${task_text}

Steps:
1. Implement the task described above. It is currently marked '- [\]' (in progress) in the WPRD.
2. Follow all Rules of Engagement above. Violations will cause the task to fail review.
3. When done, update the WPRD to mark the task as completed: change '- [\]' to '- [+]'.
4. If the task has verify: lines below it, those are shell commands that will be run
   after you finish to check your work. Make sure your output satisfies them.
${accept_block}
TASK NOTATION:
  - [ ] = pending (to do)
  - [\] = in progress (being worked on)
  - [+] = completed (done successfully)
  - [x] = failed (do not touch these)

WHEN MARKING A TASK COMPLETE:
  - Change the marker from [\] to [+]. Do NOT modify the task text itself.
  - Add any results, output, or notes as indented bullet points BELOW the task line.
  - Place result lines BEFORE any verify: or accept: lines.
  - Example:
    - [+] Ping google.com 5 times and calculate the average latency
      - avg: 7.712 ms (min: 7.1, max: 8.4)
      verify: test -f results.txt

ONLY WORK ON THIS SINGLE TASK. Do NOT touch other tasks.
If ALL tasks in the WPRD are completed or failed (no [ ] or [\] remain), output <promise>COMPLETE</promise>.
EOF
}

# Build the prompt for single-task mode.
build_single_prompt() {
  local task="$1"
  cat << EOF
Task: $task

Implement this task fully. Work autonomously until complete.
EOF
}

# ============================================================================
# AI ENGINE
#
# Runs opencode in non-interactive mode with JSON output. The
# OPENCODE_PERMISSION environment variable grants full auto-approval
# for all tool calls -- this is intentional for autonomous operation.
# ============================================================================

# Launch the AI engine as a background process.
# Sets global: ai_pid, log_stream_pid
# Increments: total_agent_calls
#
# Output goes directly to the output file. A background `tail -f` streams
# a copy to the run log so the user can follow along with `tail -f` on
# the log file. The tail process is cleaned up by stop_log_stream().
run_ai_command() {
  local prompt=$1
  local output_file=$2

  ((total_agent_calls++)) || true

  # Log the prompt being sent
  log_to_file "AGENT CALL #${total_agent_calls} - PROMPT SENT" "$prompt"

  # Build command as an array to avoid word-splitting issues with
  # MODEL_OVERRIDE or prompt values containing special characters.
  local cmd_args=(opencode run --agent team7 --format json)
  [[ -n "$MODEL_OVERRIDE" ]] && cmd_args+=(--model "$MODEL_OVERRIDE")
  cmd_args+=("$prompt")

  OPENCODE_PERMISSION='{"*":"allow"}' "${cmd_args[@]}" \
    > "$output_file" 2>/dev/null &

  ai_pid=$!

  # Stream a live copy of the output to the run log. Uses tail -f to
  # follow the output file from the beginning. Killed by stop_log_stream()
  # after the AI finishes.
  if [[ -n "$run_log" ]]; then
    tail -f -n +1 "$output_file" >> "$run_log" 2>/dev/null &
    log_stream_pid=$!
  fi
}

# Wait for the AI process to finish, with a timeout watchdog.
# Kills the AI process if it exceeds AI_TIMEOUT seconds.
# Resets ai_pid and watchdog_pid after completion.
wait_for_ai() {
  # Start watchdog timer
  ( sleep "$AI_TIMEOUT" && kill "$ai_pid" 2>/dev/null ) &
  watchdog_pid=$!

  wait "$ai_pid" 2>/dev/null || true
  ai_pid=""

  # Cancel watchdog
  kill "$watchdog_pid" 2>/dev/null || true
  wait "$watchdog_pid" 2>/dev/null || true
  watchdog_pid=""
}

# Stop the progress monitor and clear the spinner line.
# Resets monitor_pid after completion.
stop_monitor() {
  if [[ -n "$monitor_pid" ]]; then
    kill "$monitor_pid" 2>/dev/null || true
    wait "$monitor_pid" 2>/dev/null || true
    monitor_pid=""
  fi
  tput cr 2>/dev/null || printf "\r"
  tput el 2>/dev/null || true
}

# Stop the background log stream (tail -f) that copies AI output to the
# run log. Waits briefly to let tail flush any remaining data before killing.
# Resets log_stream_pid after completion.
stop_log_stream() {
  if [[ -n "$log_stream_pid" ]]; then
    sleep 0.5 2>/dev/null || sleep 1  # let tail flush final data
    kill "$log_stream_pid" 2>/dev/null || true
    wait "$log_stream_pid" 2>/dev/null || true
    log_stream_pid=""
  fi
}

# Parse the AI engine's JSON output to extract the response text,
# token counts, and cost. Writes results to the provided nameref
# variables to avoid the fragile echo-with-sentinel pattern.
#
# Args: $1=raw_result  $2=&response  $3=&input_tokens
#       $4=&output_tokens  $5=&cost
parse_ai_result() {
  local result=$1
  local -n _response=$2
  local -n _input_tokens=$3
  local -n _output_tokens=$4
  local -n _cost=$5

  _response=""
  _input_tokens=0
  _output_tokens=0
  _cost="0"

  local step_finish
  step_finish=$(printf '%s\n' "$result" | grep '"type":"step_finish"' | tail -1 || true)

  if [[ -n "$step_finish" ]]; then
    _input_tokens=$(printf '%s' "$step_finish" | jq -r '.part.tokens.input // 0' 2>/dev/null || echo "0")
    _output_tokens=$(printf '%s' "$step_finish" | jq -r '.part.tokens.output // 0' 2>/dev/null || echo "0")
    _cost=$(printf '%s' "$step_finish" | jq -r '.part.cost // 0' 2>/dev/null || echo "0")
  fi

  _response=$(printf '%s\n' "$result" | grep '"type":"text"' | jq -rs 'map(.part.text // "") | join("")' 2>/dev/null || true)

  if [[ -z "$_response" ]]; then
    _response="Task completed"
  fi

  # Sanitize token counts to integers.
  is_uint "$_input_tokens"  || _input_tokens=0
  is_uint "$_output_tokens" || _output_tokens=0
}

# Check the AI output for error messages. Returns 0 if no errors found.
# On error, prints the error message to stdout and returns 1.
check_for_errors() {
  local result=$1

  if printf '%s\n' "$result" | grep -q '"type":"error"'; then
    local error_msg
    error_msg=$(printf '%s\n' "$result" | grep '"type":"error"' | head -1 \
      | jq -r '.error.data.message // .error.message // .message // "Unknown error"' 2>/dev/null \
      || echo "Unknown error")
    printf '%s' "$error_msg"
    return 1
  fi

  return 0
}

# Accumulate token counts and cost into the global totals.
# Validates cost is numeric before passing to bc.
accumulate_usage() {
  local input_tokens=$1
  local output_tokens=$2
  local actual_cost=$3

  is_uint "$input_tokens"  || input_tokens=0
  is_uint "$output_tokens" || output_tokens=0

  total_input_tokens=$((total_input_tokens + input_tokens))
  total_output_tokens=$((total_output_tokens + output_tokens))

  # Only accumulate cost if it's a valid number and bc is available.
  if is_numeric "$actual_cost" && [[ "$actual_cost" != "0" ]] && command -v bc &>/dev/null; then
    total_actual_cost=$(echo "scale=6; $total_actual_cost + $actual_cost" | bc 2>/dev/null || echo "$total_actual_cost")
  fi
}

# ============================================================================
# SINGLE TASK EXECUTION (one-shot)
# ============================================================================

run_single_task_once() {
  local task="$1"

  echo ""
  printf '  %s%s%s\n\n' "${L7_GOLD}" "$task" "${RESET}"

  local prompt
  prompt=$(build_single_prompt "$task")

  if [[ "$DRY_RUN" == true ]]; then
    printf '%s' "${L7_BLUE}"
    printf '%s\n' "$prompt" | sed 's/^/  /'
    printf '%s' "${RESET}"
    return 0
  fi

  tmpfile=$(mktemp -t l7.XXXXXX)

  # Run AI with progress monitor
  run_ai_command "$prompt" "$tmpfile"

  monitor_progress "$tmpfile" "${task:0:40}" &
  monitor_pid=$!

  wait_for_ai
  stop_monitor
  stop_log_stream

  local result
  result=$(cat "$tmpfile" 2>/dev/null || true)

  if [[ -z "$result" ]]; then
    log_error "Empty response"
    rm -f "$tmpfile"
    tmpfile=""
    return 1
  fi

  # Parse result using nameref variables (no sentinel delimiter needed).
  local response="" input_tokens=0 output_tokens=0 actual_cost="0"
  parse_ai_result "$result" response input_tokens output_tokens actual_cost

  # Log parsed stats (raw JSON was already streamed to the log via tail)
  log_to_file "AGENT RESPONSE PARSED" "Tokens: ${input_tokens} in / ${output_tokens} out | Cost: ${actual_cost}"

  printf "  ${L7_GOLD}${BOLD}+${RESET} ${L7_GOLD}done${RESET}\n"

  accumulate_usage "$input_tokens" "$output_tokens" "$actual_cost"

  rm -f "$tmpfile"
  tmpfile=""
  return 0
}

# ============================================================================
# WPRD TASK EXECUTION (loop iteration)
#
# Picks the next pending or in-progress task from the WPRD, marks it [\]
# (in progress), sends the full WPRD as context to the AI engine, and
# waits for completion. After the AI finishes, runs verification layers.
#
# On success: marks the task [+] (completed).
# On failure after all retries (or when MAX_RETRIES is 0, indefinitely
# until success): marks the task [x] (failed).
#
# Return codes:
#   0 = task completed and verified, more tasks remain
#   1 = task failed after all retries exhausted (marked [x])
#   2 = all tasks done (no [ ] or [\] remain)
# ============================================================================

run_wprd_task() {
  local retry_count=0

  local current_task
  current_task=$(get_next_task)

  if [[ -z "$current_task" ]]; then
    return 2  # No actionable tasks
  fi

  # Mark task as in-progress: [ ] -> [\]
  mark_task_in_progress "$current_task"

  show_task_dashboard

  tmpfile=$(mktemp -t l7.XXXXXX)

  if [[ "$DRY_RUN" == true ]]; then
    local task_line
    task_line=$(find_task_line "$current_task")
    local prompt
    prompt=$(build_wprd_prompt "$task_line" "$current_task")
    printf '%s' "${L7_BLUE}"
    printf '%s\n' "$prompt" | sed 's/^/  /'
    printf '%s' "${RESET}"
    # Show verify commands and accept criteria if any
    if [[ -n "$task_line" ]]; then
      local verify_cmds
      verify_cmds=$(get_verify_commands "$task_line")
      if [[ -n "$verify_cmds" ]]; then
        echo ""
        printf '  %s\n' "${L7_BLUE}verify${RESET}"
        printf '%s\n' "$verify_cmds" | while IFS= read -r cmd; do
          printf '    %s\n' "${L7_BLUE}\$${RESET} ${L7_BLUE}$cmd${RESET}"
        done
      fi
      local accept_crit
      accept_crit=$(get_accept_criteria "$task_line")
      if [[ -n "$accept_crit" ]]; then
        echo ""
        printf '  %s\n' "${L7_BLUE}accept${RESET}"
        printf '%s\n' "$accept_crit" | while IFS= read -r crit; do
          printf '    %s\n' "${L7_BLUE}-${RESET} ${L7_BLUE}$crit${RESET}"
        done
      fi
    fi
    rm -f "$tmpfile"
    tmpfile=""
    return 0
  fi

  # Retry loop for transient failures (empty responses, API errors,
  # failed verify checks, or failed AI review). When MAX_RETRIES is 0
  # (unlimited), the loop runs indefinitely until the task succeeds.
  while ! retries_exhausted "$retry_count"; do
    # Ensure the task is marked [\] before each attempt. The AI may have
    # marked it [+] during a previous failed attempt (verify/review failed
    # after the AI completed its work). Without this reset, the AI would
    # see the task as [+] and skip it or work on the wrong task.
    ensure_task_in_progress "$current_task"

    # Build the prompt fresh each attempt. This picks up any WPRD changes
    # from prior attempts and uses the current task line number for
    # accurate accept: criteria extraction.
    local task_line
    task_line=$(find_task_line "$current_task")
    local prompt
    prompt=$(build_wprd_prompt "$task_line" "$current_task")

    # Truncate output file before each attempt to prevent stale data.
    : > "$tmpfile"

    run_ai_command "$prompt" "$tmpfile"

    monitor_progress "$tmpfile" "${current_task:0:40}" &
    monitor_pid=$!

    wait_for_ai
    stop_monitor
    stop_log_stream

    local result
    result=$(cat "$tmpfile" 2>/dev/null || true)

    # Check for empty response.
    if [[ -z "$result" ]]; then
      ((retry_count++)) || true
      log_error "Empty response ($(format_retry_count "$retry_count"))"
      if ! retries_exhausted "$retry_count"; then
        log_info "Retrying in ${RETRY_DELAY}s..."
        sleep "$RETRY_DELAY"
        continue
      fi
      rm -f "$tmpfile"
      tmpfile=""
      mark_task_failed "$current_task"
      return 1
    fi

    # Check for API errors.
    local error_msg
    if ! error_msg=$(check_for_errors "$result"); then
      ((retry_count++)) || true
      log_error "$error_msg ($(format_retry_count "$retry_count"))"
      if ! retries_exhausted "$retry_count"; then
        log_info "Retrying in ${RETRY_DELAY}s..."
        sleep "$RETRY_DELAY"
        continue
      fi
      rm -f "$tmpfile"
      tmpfile=""
      mark_task_failed "$current_task"
      return 1
    fi

    # Parse result.
    local response="" input_tokens=0 output_tokens=0 actual_cost="0"
    parse_ai_result "$result" response input_tokens output_tokens actual_cost

    # Log parsed stats (raw JSON was already streamed to the log via tail)
    log_to_file "AGENT RESPONSE PARSED" "Task: ${current_task:0:60}\nTokens: ${input_tokens} in / ${output_tokens} out | Cost: ${actual_cost}"

    printf "  ${L7_GOLD}${BOLD}+${RESET} ${L7_GOLD}done${RESET}  ${DIM}${current_task:0:40}${RESET}\n"

    accumulate_usage "$input_tokens" "$output_tokens" "$actual_cost"

    rm -f "$tmpfile"
    tmpfile=""

    # Re-locate the task line after the AI modified the WPRD.
    # The AI may have inserted result lines, shifting line numbers.
    task_line=$(find_task_line "$current_task")

    # ---- VERIFICATION LAYER 1: verify: checks ----
    if [[ -n "$task_line" ]]; then
      local verify_rc=0
      run_verify_checks "$task_line" "$current_task" || verify_rc=$?

      if [[ $verify_rc -ne 0 ]]; then
        ((retry_count++)) || true
        log_warn "Verify checks failed ($(format_retry_count "$retry_count"))"
        if ! retries_exhausted "$retry_count"; then
          log_info "Retrying task in ${RETRY_DELAY}s..."
          sleep "$RETRY_DELAY"
          continue
        fi
        mark_task_failed "$current_task"
        return 1
      fi
    fi

    # ---- VERIFICATION LAYER 2: AI review ----
    local review_rc=0
    run_ai_review "$current_task" "$task_line" || review_rc=$?

    if [[ $review_rc -ne 0 ]]; then
      ((retry_count++)) || true
      log_warn "AI review failed ($(format_retry_count "$retry_count"))"
      if ! retries_exhausted "$retry_count"; then
        log_info "Retrying task in ${RETRY_DELAY}s..."
        sleep "$RETRY_DELAY"
        continue
      fi
      mark_task_failed "$current_task"
      return 1
    fi

    # ---- Both verifications passed (or were disabled) ----

    # Mark the task as completed: [\] -> [+]
    # Also handles the case where the AI already marked it [+] directly.
    if [[ -n "$task_line" ]]; then
      local current_marker
      current_marker=$(sed -n "${task_line}p" "$WPRD_FILE" 2>/dev/null || true)
      if [[ "$current_marker" != *"[+]"* ]]; then
        log_debug "Marking task as completed [+]"
        mark_task_done "$current_task"
      fi
    else
      # Fallback: try to mark by text match
      mark_task_done "$current_task"
    fi

    local remaining_after in_progress_after
    remaining_after=$(count_remaining)
    in_progress_after=$(count_in_progress)
    remaining_after="${remaining_after//[[:space:]]/}"
    in_progress_after="${in_progress_after//[[:space:]]/}"
    remaining_after=${remaining_after:-0}
    in_progress_after=${in_progress_after:-0}
    local actionable=$((remaining_after + in_progress_after))

    if [[ "$actionable" -eq 0 ]]; then
      return 2  # All tasks done
    fi

    # AI might claim completion but tasks remain -- continue.
    if [[ "$result" == *"<promise>COMPLETE</promise>"* ]]; then
      log_debug "AI claimed completion but $actionable tasks remain"
    fi

    return 0
  done

  # All retries exhausted (only reachable when MAX_RETRIES > 0) -- mark task as failed: [\] -> [x]
  mark_task_failed "$current_task"
  return 1
}

# ============================================================================
# SUMMARY
# ============================================================================

show_summary() {
  # Write the stats file first (before displaying)
  write_stats_file

  local completed remaining failed in_progress total
  if [[ -n "$WPRD_FILE" ]] && [[ -f "$WPRD_FILE" ]]; then
    completed=$(count_completed)
    remaining=$(count_remaining)
    failed=$(count_failed)
    in_progress=$(count_in_progress)
  else
    completed=0; remaining=0; failed=0; in_progress=0
  fi
  completed="${completed//[[:space:]]/}"; completed=${completed:-0}
  remaining="${remaining//[[:space:]]/}"; remaining=${remaining:-0}
  failed="${failed//[[:space:]]/}"; failed=${failed:-0}
  in_progress="${in_progress//[[:space:]]/}"; in_progress=${in_progress:-0}
  total=$((completed + failed + in_progress + remaining))

  local term_width
  term_width=$(tput cols 2>/dev/null || echo 80)
  local bar_width=$((term_width - 28))
  [[ $bar_width -lt 10 ]] && bar_width=10
  [[ $bar_width -gt 50 ]] && bar_width=50

  # Compute elapsed
  local elapsed_str="-"
  if [[ -n "$run_start_time" ]]; then
    local now=$(($(date +%s) - run_start_time))
    elapsed_str=$(format_elapsed "$now")
  fi

  # Format cost
  local cost_fmt
  cost_fmt=$(format_cost "$total_actual_cost")
  local total_tokens=$((total_input_tokens + total_output_tokens))

  echo ""
  printf '  %s%scomplete%s\n' "${L7_GOLD}" "${BOLD}" "${RESET}"
  echo ""

  # Progress bar
  printf '  '
  local bar_str
  bar_str=$(draw_progress_bar "$completed" "$total" "$bar_width")
  printf '%s\n' "${L7_BLUE}${bar_str}${RESET}"
  echo ""

  # Stats -- one item per line, no column alignment issues with ANSI codes
  printf "  ${L7_BLUE}elapsed${RESET}  ${L7_GOLD}%s${RESET}\n" "$elapsed_str"
  printf "  ${L7_BLUE}calls${RESET}    ${L7_GOLD}%d${RESET}\n" "$total_agent_calls"
  printf "  ${L7_BLUE}tokens${RESET}   ${DIM}%d${RESET}\n" "$total_tokens"
  printf "  ${L7_BLUE}cost${RESET}     ${L7_GOLD}${BOLD}%s${RESET}\n" "$cost_fmt"

  # Verification summary
  local total_verify=$((total_verify_passed + total_verify_failed))
  local total_review=$((total_review_passed + total_review_failed))
  if [[ $total_verify -gt 0 ]] || [[ $total_review -gt 0 ]]; then
    printf "  ${L7_BLUE}checks${RESET}  "
    [[ $total_verify -gt 0 ]] && printf " ${L7_GOLD}%d${RESET}${DIM}/%d verify${RESET}" "$total_verify_passed" "$total_verify"
    [[ $total_review -gt 0 ]] && printf "  ${L7_GOLD}%d${RESET}${DIM}/%d review${RESET}" "$total_review_passed" "$total_review"
    echo ""
  fi

  # File locations
  if [[ -n "$run_log" ]]; then
    echo ""
    printf "  ${DIM}log    %s${RESET}\n" "$run_log"
    printf "  ${DIM}stats  %s${RESET}\n" "$run_stats"
    if [[ -n "$run_dir" ]] && [[ -n "$run_label" ]]; then
      local wprd_copy="${run_dir}/${run_label}_wprd.md"
      [[ -f "$wprd_copy" ]] && printf "  ${DIM}wprd   %s${RESET}\n" "$wprd_copy"
    fi
  fi
  echo ""
}

# ============================================================================
# MAIN
# ============================================================================

main() {
  parse_args "$@"

  trap cleanup EXIT
  trap 'exit 130' INT TERM HUP

  check_requirements

  print_logo

  # --- Single task mode ---
  if [[ "$MODE" == "single" ]]; then
    init_run_dir "single_task"
    printf '  %ssingle task%s\n' "${DIM}" "${RESET}"
    printf '  %stail -f %s%s\n\n' "${DIM}" "${run_log/#$HOME/\~}" "${RESET}"

    local rc=0
    run_single_task_once "$SINGLE_TASK" || rc=$?
    show_summary
    exit $rc
  fi

  # --- WPRD mode ---
  local wprd_title
  wprd_title=$(get_wprd_title)
  init_run_dir "${wprd_title:-$(basename "$WPRD_FILE" .md)}"

  local banner="  ${L7_BLUE}${WPRD_FILE}${RESET}"
  if [[ -n "$wprd_title" ]]; then
    banner="  ${L7_GOLD}${BOLD}${wprd_title}${RESET}  ${DIM}${WPRD_FILE}${RESET}"
  fi

  local mode_parts=()
  [[ "$DRY_RUN" == true ]] && mode_parts+=("dry-run")
  [[ $MAX_ITERATIONS -gt 0 ]] && mode_parts+=("max:$MAX_ITERATIONS")
  [[ -n "$MODEL_OVERRIDE" ]] && mode_parts+=("model:$MODEL_OVERRIDE")
  [[ "$VERIFY_ENABLED" != true ]] && mode_parts+=("no-verify")
  [[ "$REVIEW_ENABLED" != true ]] && mode_parts+=("no-review")

  if [[ ${#mode_parts[@]} -gt 0 ]]; then
    banner+="  ${DIM}${mode_parts[*]}${RESET}"
  fi

  printf '%s\n' "$banner"
  printf '  %stail -f %s%s\n' "${DIM}" "${run_log/#$HOME/\~}" "${RESET}"

  # Main loop: iterate until all tasks complete, max iterations reached,
  # or consecutive failures exceed threshold.
  while true; do
    ((iteration++)) || true
    local result_code=0
    run_wprd_task || result_code=$?

    case $result_code in
      0)
        consecutive_failures=0
        ;;
      1)
        ((consecutive_failures++)) || true
        if [[ $consecutive_failures -ge 3 ]]; then
          log_error "3 consecutive task failures. Stopping."
          show_summary
          exit 1
        fi
        log_warn "Task failed ($consecutive_failures/3 consecutive). Retrying..."
        sleep "$RETRY_DELAY"
        ;;
      2)
        show_summary
        exit 0
        ;;
    esac

    if [[ $MAX_ITERATIONS -gt 0 ]] && [[ $iteration -ge $MAX_ITERATIONS ]]; then
      log_warn "Max iterations ($MAX_ITERATIONS)"
      show_summary
      exit 0
    fi

    sleep 1
  done
}

main "$@"
