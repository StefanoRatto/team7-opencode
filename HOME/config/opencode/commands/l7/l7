  print_logo
  # Color roles:
  #   G   = gold -> brand, structural separators, completed
  #   GW  = gold bold -> section titles
  #   AW  = blue bold -> flags, keywords (scannable)
  #   A   = blue -> values, arguments, active items
  #   B   = blue -> descriptions, secondary text
  #   D   = dim -> defaults, parenthetical hints
  local A="${L7_BLUE}" AW="${L7_BLUE}${BOLD}" G="${L7_GOLD}" GW="${L7_GOLD}${BOLD}"
  local RD="${L7_BLUE}" B="${L7_BLUE}" D="${DIM}" R="${RESET}"

