#!/usr/bin/env bash

# ============================================================================
# l7 - Loop 7 - Autonomous AI Task Loop
# Powered by team7
#
# Reads a WPRD.md file containing instructions, rules, and a task checklist,
# then iterates through each pending task by delegating to the team7
# AI engine. Tasks transition through 4 states:
#   [ ] pending -> [\] in progress -> [+] completed  or  [x] failed
#
# Three optional verification layers ensure tasks are actually done:
#   1. Verify checks: shell commands defined in the WPRD that must exit 0
#   2. Accept criteria: natural-language conditions checked by AI review
#   3. AI review: a second AI pass that inspects the work and confirms
#
# Also supports single-task mode for one-off AI-driven work.
#
# Usage:
#   l7 path/to/WPRD.md          WPRD mode (explicit file)
#   l7 "task description"        Single task mode
#
# Requirements: opencode/team7 (AI engine), jq (JSON parsing)
# Optional:     bc (cost calculation)
# ============================================================================

set -euo pipefail

# ============================================================================
# CONFIGURATION & DEFAULTS
# ============================================================================

# --- Runtime options (set by parse_args) ---
WPRD_FILE=""
SINGLE_TASK=""
MODE=""              # "wprd" or "single"
MODEL_OVERRIDE=""
DRY_RUN=false
MAX_ITERATIONS=0     # 0 = unlimited
MAX_RETRIES=0     # 0 = unlimited
RETRY_DELAY=5
VERBOSE=false
AI_TIMEOUT=900                 # seconds; max per worker AI call
REVIEW_TIMEOUT=300             # seconds; max per review AI call
VERIFY_ENABLED=true            # run verify: checks from WPRD
REVIEW_ENABLED=true            # run AI review pass after task

# --- Terminal colors ---
# The palette: gold (#a57c00) and blue (#00b0f0).
# Detect color support once at startup. Falls back to empty strings when
# stdout is not a terminal or tput is unavailable.
if [[ -t 1 ]] && command -v tput &>/dev/null && [[ $(tput colors 2>/dev/null || echo 0) -ge 8 ]]; then
  BOLD=$(tput bold)
  DIM=$(tput dim)
  RESET=$(tput sgr0)
  if [[ $(tput colors 2>/dev/null || echo 0) -ge 256 ]]; then
    L7_GOLD=$(printf '\033[38;2;165;124;0m')
    L7_BLUE=$(printf '\033[38;2;0;176;240m')
  else
    L7_GOLD=$(tput setaf 3)
    L7_BLUE=$(tput setaf 4)
  fi
  L7_ERR="${L7_GOLD}${BOLD}"
else
  BOLD="" DIM="" RESET="" L7_GOLD="" L7_BLUE="" L7_ERR=""
fi

# --- Mutable global state ---
ai_pid=""
monitor_pid=""
watchdog_pid=""
log_stream_pid=""
tmpfile=""
total_input_tokens=0
total_output_tokens=0
total_actual_cost="0"
total_agent_calls=0
iteration=0
consecutive_failures=0
total_verify_passed=0
total_verify_failed=0
total_review_passed=0
total_review_failed=0
run_start_time=""
run_dir=""
run_log=""
run_stats=""
run_label=""

# ============================================================================
# UTILITY FUNCTIONS
# ============================================================================

# Log helpers. Warnings, errors, and informational messages go to stderr
# so they don't corrupt piped stdout output. Body text is colored to
# match the severity.
log_info()  { printf '%s\n' "  ${L7_BLUE}[INFO]${RESET} ${L7_BLUE}$*${RESET}" >&2; }
log_warn()  { printf '%s\n' "  ${L7_BLUE}[WARN]${RESET} ${L7_BLUE}$*${RESET}" >&2; }
log_error() { printf '%s\n' "  ${L7_ERR}[ERROR]${RESET} ${L7_ERR}$*${RESET}" >&2; }
log_debug() { [[ "$VERBOSE" == true ]] && printf '%s\n' "  ${DIM}[DEBUG] $*${RESET}" >&2 || true; }
log_pass()  { printf '%s\n' "  ${L7_GOLD}[PASS]${RESET} ${L7_BLUE}$*${RESET}"; }
log_fail()  { printf '%s\n' "  ${L7_ERR}[FAIL]${RESET} ${L7_ERR}$*${RESET}"; }

# Print error, show help, and exit.
die_usage() {
  log_error "$1"
  echo ""
  show_help
  exit 1
}

# Validate that a string is a non-negative integer.
# Usage: is_uint "$value" || die_usage "..."
is_uint() { [[ "${1:-}" =~ ^[0-9]+$ ]]; }

# Check whether retries are exhausted. Returns 0 (true) if the retry count
# has reached the limit. When MAX_RETRIES is 0 (unlimited), always returns 1
# (false) -- retries never run out.
retries_exhausted() {
  local count=$1
  [[ $MAX_RETRIES -gt 0 ]] && [[ $count -ge $MAX_RETRIES ]];
}

# Format retry count for display. Shows "3/5" when limited, "3" when unlimited.
format_retry_count() {
  local count=$1
  if [[ $MAX_RETRIES -gt 0 ]]; then
    printf '%d/%d' "$count" "$MAX_RETRIES"
  else
    printf '%d' "$count"
  fi
}

# Validate that a string looks like a non-negative decimal number.
# Accepts integers (42) and decimals (3.14). Rejects everything else.
is_numeric() { [[ "${1:-}" =~ ^[0-9]+\.?[0-9]*$ ]]; }

# Format an elapsed time in seconds to human-readable HH:MM:SS or MM:SS.
format_elapsed() {
  local secs=$1
  local hrs=$((secs / 3600))
  local mins=$(( (secs % 3600) / 60 ))
  local s=$((secs % 60))
  if [[ $hrs -gt 0 ]]; then
    printf '%dh %02dm %02ds' "$hrs" "$mins" "$s"
  elif [[ $mins -gt 0 ]]; then
    printf '%dm %02ds' "$mins" "$s"
  else
    printf '%ds' "$s"
  fi
}

# Format cost to 2 decimal places with leading zero.
# Returns "n/a" when cost data is unavailable (0 with tokens present).
# Forces C locale to ensure dot decimal separator regardless of system locale.
format_cost() {
  local raw=$1
  if is_numeric "$raw" && [[ "$raw" != "0" ]] && command -v bc &>/dev/null; then
    LC_NUMERIC=C printf '$%.2f' "$(echo "$raw" | bc -l 2>/dev/null)" 2>/dev/null || echo "$raw"
  else
    echo "n/a"
  fi
}

# ============================================================================
# RUN DIRECTORY & LOGGING
#
# Each execution creates a unique directory under ~/.l7/
# named with a UTC timestamp and the WPRD title. Two files are written:
#   - <label>.log  : full interaction log (prompts sent, responses received)
#   - <label>.txt  : run stats summary (written at completion)
# ============================================================================

# Initialize the run directory and log files.
# Sets globals: run_dir, run_log, run_stats, run_label, run_start_time
init_run_dir() {
  local title="${1:-single_task}"

  run_start_time=$(date +%s)

  # Build label: UTC timestamp + sanitized title
  local ts
  ts=$(date -u +"%Y%m%dT%H%M%SZ")
  local safe_title
  safe_title=$(printf '%s' "$title" | tr '[:upper:]' '[:lower:]' | sed 's/[^a-z0-9]/_/g' | sed 's/__*/_/g' | sed 's/^_//;s/_$//')
  run_label="${ts}_${safe_title}"

  run_dir="${HOME}/.l7/${run_label}"
  mkdir -p "$run_dir"

  run_log="${run_dir}/${run_label}.log"
  run_stats="${run_dir}/${run_label}.txt"

  # Write log header
  {
    echo "loop 7 · execution log"
    echo ""
    echo "started    $(date -u +"%Y-%m-%d %H:%M:%S UTC")"
    echo "wprd       ${WPRD_FILE:-n/a}"
    echo "title      ${title}"
    echo "model      ${MODEL_OVERRIDE:-default}"
    echo "run id     ${run_label}"
    echo ""
  } > "$run_log"
}

# Append a timestamped entry to the run log.
# Usage: log_to_file "SECTION_HEADER" "content"
log_to_file() {
  local header=$1
  local content=${2:-}
  [[ -z "$run_log" ]] && return

  {
    printf '[%s] %s\n' "$(date -u +"%H:%M:%S")" "$header"
    if [[ -n "$content" ]]; then
      echo "$content"
    fi
    echo ""
  } >> "$run_log"
}

# Append raw AI JSON output to the run log (for full fidelity).
log_ai_raw() {
  local label=$1
  local file=$2
  [[ -z "$run_log" ]] && return
  [[ ! -f "$file" ]] && return

  {
    printf '[%s] %s · raw json\n' "$(date -u +"%H:%M:%S")" "$label"
    cat "$file"
    echo ""
  } >> "$run_log"
}

# Write the final stats file.
write_stats_file() {
  [[ -z "$run_stats" ]] && return

  local end_time
  end_time=$(date +%s)
  local elapsed=$((end_time - run_start_time))
  local elapsed_fmt
  elapsed_fmt=$(format_elapsed "$elapsed")

  local completed remaining failed in_progress total
  if [[ -n "$WPRD_FILE" ]] && [[ -f "$WPRD_FILE" ]]; then
    completed=$(count_completed)
    remaining=$(count_remaining)
    failed=$(count_failed)
    in_progress=$(count_in_progress)
  else
    completed=0; remaining=0; failed=0; in_progress=0
  fi
  completed="${completed//[[:space:]]/}"; completed=${completed:-0}
  remaining="${remaining//[[:space:]]/}"; remaining=${remaining:-0}
  failed="${failed//[[:space:]]/}"; failed=${failed:-0}
  in_progress="${in_progress//[[:space:]]/}"; in_progress=${in_progress:-0}
  total=$((completed + failed + in_progress + remaining))

  local total_tokens=$((total_input_tokens + total_output_tokens))
  local cost_fmt
  cost_fmt=$(format_cost "$total_actual_cost")

  {
    echo "loop 7 · run stats"
    echo ""
    echo "run id      ${run_label}"
    echo "wprd        ${WPRD_FILE:-n/a}"
    echo "started     $(date -u -d @"$run_start_time" +"%Y-%m-%d %H:%M:%S UTC" 2>/dev/null || date -u +"%Y-%m-%d %H:%M:%S UTC")"
    echo "finished    $(date -u +"%Y-%m-%d %H:%M:%S UTC")"
    echo "elapsed     ${elapsed_fmt}"
    echo ""
    echo "tasks       ${completed} completed  ${failed} failed  ${total} total"
    echo "calls       ${total_agent_calls}"
    echo "tokens      ${total_input_tokens} in  ${total_output_tokens} out  ${total_tokens} total"
    echo "cost        ${cost_fmt}"
    echo ""
    echo "verify      ${total_verify_passed} passed  ${total_verify_failed} failed"
    echo "review      ${total_review_passed} passed  ${total_review_failed} failed"
    echo ""
    echo "log         ${run_log}"
    echo "stats       ${run_stats}"
  } > "$run_stats"

  # Also append completion to the log
  log_to_file "complete" "elapsed ${elapsed_fmt} · ${total_agent_calls} calls · ${cost_fmt}"

  # Copy final WPRD to run directory
  if [[ -n "$WPRD_FILE" ]] && [[ -f "$WPRD_FILE" ]] && [[ -n "$run_dir" ]]; then
    cp "$WPRD_FILE" "${run_dir}/${run_label}_wprd.md" 2>/dev/null || true
  fi
}

# Print the l7 logo.
print_logo() {
  printf '%s%s' "${L7_GOLD}" "${BOLD}"
  cat << 'LOGO'

       _/          _/_/      _/_/    _/_/_/    _/_/_/_/
      _/        _/    _/  _/    _/  _/    _/       _/
     _/        _/    _/  _/    _/  _/_/_/        _/
    _/        _/    _/  _/    _/  _/           _/
   _/_/_/_/    _/_/      _/_/    _/          _/
LOGO
  printf '\n%s' "${RESET}"
}

# ============================================================================
# HELP
# ============================================================================

